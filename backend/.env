# Copy to .env and adjust. For on-prem production, point DATABASE_URL at PostgreSQL
# (e.g. postgresql+psycopg://user:pass@localhost:5432/terracrest) — no code changes needed.
TERRACREST_DATABASE_URL=sqlite:///./terracrest.db
TERRACREST_JWT_SECRET=change-me-to-a-long-random-string-in-production
TERRACREST_ACCESS_TOKEN_MINUTES=15
TERRACREST_CORS_ORIGINS=http://localhost:5173,http://localhost:5178,https://terracrest.vercel.app
# Host header allow-list (TrustedHostMiddleware). Add your real Render domain
# and any custom domain you point at the API. "testserver" must stay for tests.
TERRACREST_ALLOWED_HOSTS=localhost,127.0.0.1,terracrest-api.onrender.com,testserver
